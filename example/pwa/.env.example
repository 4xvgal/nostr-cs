# Comma-separated wss:// URLs.
# Only PUBLIC_* vars are exposed to the browser bundle (SvelteKit convention).

# Used as the default Bootstrap list shown on the setup page and the seed
# for kind 0 / 10002 / 10050 lookups.
PUBLIC_BOOTSTRAP_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# Optional overrides — leave blank to fall back to the bootstrap list.
PUBLIC_WRITE_RELAYS=
PUBLIC_READ_RELAYS=
PUBLIC_DM_RELAYS=

# Blossom servers for encrypted attachment uploads. Comma-separated; leftmost
# is the primary upload target, others are mirror hints used for download
# fallback. One server is fine for a demo.
PUBLIC_BLOSSOM_SERVERS=https://blossom.primal.net
